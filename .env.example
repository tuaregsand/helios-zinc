# Shared routing
HELIOS_CLUSTER=mainnet-beta
HELIOS_GATEWAY_SOURCE=yellowstone
HELIOS_KAFKA_BROKERS=localhost:9092
HELIOS_RAW_TX_TOPIC=helios.raw_tx

# AWS deploy controls (used by infra/aws/scripts/*.sh)
PROJECT=helios
ENVIRONMENT=prod
AWS_REGION=us-east-1
ENABLE_AWS_MSK=true
MSK_KAFKA_VERSION=3.6.0
MSK_BROKER_COUNT=2
MSK_INSTANCE_TYPE=kafka.m5.large
MSK_EBS_VOLUME_SIZE=100
MSK_CLIENT_BROKER=PLAINTEXT
MSK_CLOUDWATCH_LOGS_ENABLED=true
# If ENABLE_AWS_MSK=false, set HELIOS_KAFKA_BROKERS to external brokers.

# Yellowstone stream source
HELIOS_YELLOWSTONE_ENDPOINT=
HELIOS_YELLOWSTONE_X_TOKEN=your_provider_token
HELIUS_LASERSTREAM_ENDPOINT=https://your-helius-laserstream-endpoint:443
HELIUS_LASERSTREAM_API_KEY=your_helius_key
HELIOS_YELLOWSTONE_COMMITMENT=processed
HELIOS_YELLOWSTONE_FROM_SLOT=
HELIOS_YELLOWSTONE_SIGNATURE=
HELIOS_YELLOWSTONE_ACCOUNT_INCLUDE=
HELIOS_YELLOWSTONE_ACCOUNT_EXCLUDE=
HELIOS_YELLOWSTONE_ACCOUNT_REQUIRED=
HELIOS_YELLOWSTONE_INCLUDE_VOTE=false
HELIOS_YELLOWSTONE_INCLUDE_FAILED=true
HELIOS_YELLOWSTONE_MAX_DECODING_MSG_SIZE=52428800
HELIOS_YELLOWSTONE_RECONNECT_BACKOFF_MS=1000
HELIOS_YELLOWSTONE_RECONNECT_BACKOFF_MAX_MS=15000

# Decoder sink config
HELIOS_DECODER_GROUP=helios-decoder
HELIOS_CLICKHOUSE_URL=http://localhost:8123
HELIOS_CLICKHOUSE_DB=helios
HELIOS_CLICKHOUSE_USER=helios
HELIOS_CLICKHOUSE_PASSWORD=helios
HELIOS_DECODER_BATCH_SIZE=2000
HELIOS_DECODER_BATCH_FLUSH_MS=250

# Neon / Postgres (required for api-go and replay-go)
HELIOS_PG_DSN=postgres://<user>:<password>@<your-neon-host>/<db>?sslmode=require
HELIOS_HTTP_ADDR=:8090
HELIOS_HTTP_READ_TIMEOUT=10s
HELIOS_HTTP_READ_HEADER_TIMEOUT=5s
HELIOS_HTTP_WRITE_TIMEOUT=20s
HELIOS_HTTP_IDLE_TIMEOUT=120s
HELIOS_HTTP_REQUEST_TIMEOUT=15s
HELIOS_READY_TIMEOUT=2s
HELIOS_HTTP_MAX_BODY_BYTES=1048576
HELIOS_API_KEYS=replace-with-strong-key
HELIOS_RATE_LIMIT_RPS=30
HELIOS_RATE_LIMIT_BURST=60
HELIOS_RATE_LIMIT_STORE=memory
HELIOS_RATE_LIMIT_WINDOW=1s
HELIOS_RATE_LIMIT_FAIL_OPEN=false
HELIOS_RATE_LIMIT_REDIS_ADDR=
HELIOS_RATE_LIMIT_REDIS_DB=0
HELIOS_RATE_LIMIT_REDIS_PASSWORD=
HELIOS_RATE_LIMIT_REDIS_TLS=false
HELIOS_RATE_LIMIT_REDIS_PREFIX=helios:rl
HELIOS_CORS_ALLOW_ORIGINS=http://localhost:8090
HELIOS_OPENAPI_TOKEN=
HELIOS_JWT_JWKS_URL=
HELIOS_JWT_ISSUER=
HELIOS_JWT_AUDIENCE=
HELIOS_JWT_CLOCK_SKEW=30s
HELIOS_JWKS_REFRESH_INTERVAL=5m

# Edge gateway / load balancer
HELIOS_EDGE_ADDR=:8080
HELIOS_EDGE_BACKENDS=http://127.0.0.1:8090,http://127.0.0.1:8091
HELIOS_EDGE_BALANCE_POLICY=round_robin
HELIOS_EDGE_HEALTH_PATH=/healthz
HELIOS_EDGE_HEALTH_INTERVAL=5s
HELIOS_EDGE_BACKEND_TIMEOUT=5s
HELIOS_EDGE_READ_TIMEOUT=10s
HELIOS_EDGE_READ_HEADER_TIMEOUT=5s
HELIOS_EDGE_WRITE_TIMEOUT=30s
HELIOS_EDGE_IDLE_TIMEOUT=120s
HELIOS_EDGE_MAX_BODY_BYTES=1048576
HELIOS_EDGE_CIRCUIT_FAIL_THRESHOLD=5
HELIOS_EDGE_CIRCUIT_OPEN_FOR=30s
HELIOS_EDGE_RETRY_ATTEMPTS=2
HELIOS_EDGE_API_KEYS=
HELIOS_EDGE_ADMIN_TOKEN=

# Rust integration tests (gated; run only when HELIOS_IT_RUN=1)
HELIOS_IT_RUN=0
HELIOS_IT_KAFKA_BROKERS=localhost:9092
HELIOS_IT_KAFKA_TOPIC=helios.it.raw_tx
HELIOS_IT_CLICKHOUSE_URL=http://localhost:8123
HELIOS_IT_CLICKHOUSE_DB=helios
HELIOS_IT_CLICKHOUSE_USER=helios
HELIOS_IT_CLICKHOUSE_PASSWORD=helios
